# ============================================================
# gestoria-taxi · plantilla de variables de entorno (R1.0)
# ============================================================
# Copia este fichero a .env.local y rellena los valores.
# .env.local está gitignored — NUNCA se commitea.
# NUNCA pegar valores reales aquí, ni en un LLM, ni en logs.
# ------------------------------------------------------------

# --- Base de datos (PostgreSQL) ---
# DEV: contenedor Colima (docker-compose --env-file .env.local up -d), 5433 loopback.
# PROD (R2): Postgres en el host UE — mismas migraciones Prisma, datos reales SOLO ahí.
# docker-compose lee estas 3:
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# Cadena que usa Prisma/la app. Dev: postgresql://USER:PASS@127.0.0.1:5433/DB?schema=public
DATABASE_URL=

# --- Auth.js v5 (NextAuth) ---
# Secreto de firma de sesión/JWT. Generar con:  openssl rand -base64 32
AUTH_SECRET=

# --- Cifrado de campo AES-256-GCM (totpSecretEnc, documentos) ---
# Clave de 32 bytes. Generar con:  openssl rand -base64 32
# Fuera del repo. Pérdida = datos cifrados irrecuperables; fuga = datos comprometidos.
ENCRYPTION_KEY=

# --- Bóveda documental (almacenamiento de ficheros cifrados) ---
# Carpeta donde se guardan los documentos de cliente CIFRADOS en reposo.
# Gitignorada y FUERA del repo. Dev: ./storage  ·  PROD: volumen Docker persistente.
# La app crea la carpeta en runtime si no existe.
STORAGE_DIR=./storage

# --- TOTP (2FA) ---
# Emisor mostrado en la app autenticadora (Google Authenticator, etc.)
TOTP_ISSUER=

# --- Traefik / SSL (Producción) ---
# Email para registro en Let's Encrypt (SSL automático)
ACME_EMAIL=

# --- Asistente IA (capa agnóstica de proveedor) ---
# Proveedor activo: "gemini" (pruebas, AI Studio del socio) | "mistral" | "none".
# RGPD: el asistente guiado SOLO recibe estructura del trámite + manual (NUNCA datos de
# cliente). No usar AI Studio gratuito para datos sensibles (ver docs/COUNCIL-STACK-IA.md).
AI_PROVIDER=none
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

