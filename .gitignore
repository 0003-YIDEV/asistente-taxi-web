# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- gestoria-taxi · R1.0 RGPD: datos sensibles, NUNCA a git ---
# (.env* y *.pem ya cubiertos arriba)
# bóveda documental y subidas de clientes
/uploads/
/storage/
/documentos/
# volcados / backups de base de datos
*.sql
*.sqlite
*.sqlite3
*.db
*.dump
dump.rdb
# certificados y material criptográfico (cliente y app)
*.key
*.pfx
*.p12
*.crt
*.cer
*.jks
*.keystore
# secretos / claves de cifrado de campo
*.secret
secrets.*

# prisma client generado (se regenera con `prisma generate`)
/src/generated/
# las MIGRACIONES Prisma SÍ se versionan (anula el patrón *.sql de arriba)
!prisma/migrations/
!prisma/migrations/**
