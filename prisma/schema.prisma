// gestoria-taxi · schema R1.1 (solo infra/auth — SIN datos de cliente todavía)
// Prisma 7: la URL NO va aquí, va en prisma.config.ts
generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth.js v5 (@auth/prisma-adapter) ---
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?

  // Propios: control de acceso + credenciales + 2FA
  passwordHash  String? // argon2id (R1.2)
  role          String  @default("socio") // rol único hoy; extensión RBAC futura
  totpSecretEnc String? // secreto TOTP cifrado AES-256-GCM (R1.1-6)

  accounts Account[]
  sessions Session[]
  clients  Client[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id          String @id @default(cuid())
  userId      String // El asesor que gestiona este cliente
  nombre      String
  nifEnc      String // Cifrado
  domicilio   String
  ibanEnc     String // Cifrado
  email       String
  telefono    String
  numLicencia String
  matricula   String
  regimen     String

  user              User                @relation(fields: [userId], references: [id])
  checklistProgress ChecklistProgress[]
  carpetas          Carpeta[]
  documentos        Documento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistProgress {
  id        String  @id @default(cuid())
  clientId  String
  itemId    String // ID del item del checklist (estático en manual.json)
  completed Boolean @default(false)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, itemId])
}

// ───────────────────────── Bóveda documental (árbol + ficheros cifrados) ─────────────────────────
// Árbol de carpetas por cliente. parentId null = raíz. El árbol vive en BD;
// los ficheros se guardan con ruta plana por UUID (mover/renombrar = solo BD).
model Carpeta {
  id       String  @id @default(cuid())
  clientId String
  parentId String? // null = raíz del cliente

  nombre String

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent     Carpeta?    @relation("ArbolCarpetas", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hijos      Carpeta[]   @relation("ArbolCarpetas")
  documentos Documento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, parentId])
}

model Documento {
  id        String  @id @default(cuid())
  clientId  String
  carpetaId String? // null = raíz del cliente

  nombre         String
  mime           String
  tamanoBytes    Int
  rutaRelativa   String    @unique // ruta plana del fichero cifrado en STORAGE_DIR (UUID)
  hashSha256     String // integridad del contenido en claro
  origen         String    @default("subido") // "subido" | "generado"
  refModelo      String? // p.ej. "036" si lo generó el flujo de PDF del socio
  estado         String    @default("definitivo") // "borrador" | "definitivo"
  fechaDocumento DateTime? // fecha real del documento (no la de subida)
  descripcion    String?

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  carpeta Carpeta? @relation(fields: [carpetaId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, carpetaId])
  @@index([clientId, hashSha256]) // detección de duplicados
}

// --- Log de auditoría append-only (cadena de hash: lógica en R1.3) ---
model AuditLog {
  id         String   @id @default(cuid())
  ts         DateTime @default(now())
  actorId    String? // null = sistema/automatización
  actorEmail String? // snapshot legible del actor
  action     String // LOGIN, LOGIN_FAIL, READ_CLIENTE, CREATE, UPDATE, DELETE, DOC_GEN
  entity     String? // p.ej. "Cliente", "Documento"
  entityId   String?
  meta       Json? // contexto/diff (NUNCA datos sensibles en claro)
  prevHash   String? // hash de la fila previa
  hash       String   @unique // SHA-256(prevHash + campos canónicos)

  @@index([ts])
  @@index([entity, entityId])
}

// ───────────────────────── Guía de procedimientos (plantillas editables) ─────────────────────────
// Fuente de la guía visual /procedimientos y base para la automatización (instancias futuras).
model Workflow {
  id            String  @id // id legible: "alta-reta"
  servicioId    String // enlaza con los 9 servicios
  nombre        String
  refManual     String
  esOrquestador Boolean @default(false)
  orden         Int     @default(0) // orden dentro del servicio

  // Meta (campos planos = fáciles de editar en formulario)
  metaPortal         String?
  metaIdentificacion String?
  metaPlazo          String?
  metaBaseNormativa  String?
  metaResultado      String?

  // Listas simples (arrays nativos de Postgres, editables como lista de texto)
  gateEntrada  String[]
  inputs       String[]
  post         String[]
  excepciones  String[]
  autoPuede    String[]
  autoAsistido String[]
  autoNoPuede  String[]
  outputs      Json // [{ artefacto, carpeta }]

  pasos     WorkflowPaso[]
  updatedAt DateTime       @updatedAt
  createdAt DateTime       @default(now())

  @@index([servicioId])
}

model WorkflowPaso {
  id          String   @id @default(cuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  orden       Int // para reordenar pasos
  accion      String
  validacion  String?
  nivel       String // "auto" | "asistido" | "humano"
  gate        String?
  refWorkflow String?

  @@index([workflowId])
}
